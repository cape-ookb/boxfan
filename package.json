{
  "name": "boxfan",
  "version": "1.0.1",
  "description": "Serializable JSON filter descriptors for object matching, targeting, and feature flags",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/cape-ookb/boxfan.git"
  },
  "keywords": [
    "filter",
    "predicate",
    "query",
    "match",
    "targeting",
    "feature-flags",
    "serializable",
    "json",
    "remeda",
    "allPass",
    "anyPass"
  ],
  "author": "Kai Curry <kai@wjerk.com> (https://www.kaicurry.com/)",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/cape-ookb/boxfan/issues"
  },
  "homepage": "https://github.com/cape-ookb/boxfan",
  "dependencies": {
    "remeda": "^2.33.6"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
