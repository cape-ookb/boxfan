{
  "name": "boxfan",
  "version": "1.0.0",
  "description": "Serializable JSON filter predicates using Remeda",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git://github.com/cape-io/boxfan.git"
  },
  "keywords": [
    "json",
    "filter",
    "predicate",
    "serializable",
    "data"
  ],
  "author": "Kai Curry <kai@cape.io> (http://www.cape.io/)",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/cape-io/boxfan/issues"
  },
  "homepage": "https://github.com/cape-io/boxfan",
  "dependencies": {
    "remeda": "^2.33.6"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
